<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ערכת Splash לאפליקציה -->
    <style name="Theme.KMI.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/kmi_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.KMI</item>
    </style>

    <!-- ערכת עיצוב ראשית לאפליקציה -->
    <style name="Theme.KMI" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

</resources>